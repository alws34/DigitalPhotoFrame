{
    "about": {
        "image_path": "",
        "text": "Digital Photo Frame by alws34...",
        "version": "1.0.2"
    },
    "autoupdate": {
        "branch": "None",
        "enabled": true,
        "hour": 4,
        "minute": 0,
        "remote": "origin",
        "repo_path": "",
        "shallow_ok": true
    },
    "backend_configs": {
        "host": "0.0.0.0",
        "server_port": 5002,
        "stream_fps": 30,
        "stream_height": 1080,
        "stream_width": 1920,
        "supersecretkey": "YOUR_SUPERSECRET_KEY"
    },
    "effects": {
        "allow_translucent_background": true,
        "background_blur_radius": 61,
        "background_opacity": 0.4,
        "shadow_blur_radius": 71,
        "shadow_opacity": 0.85
    },
    "mqtt": {
        "base_topic": "photoframe",
        "client_id": "photoframe-livingroom",
        "discovery": true,
        "discovery_prefix": "homeassistant",
        "enabled": true,
        "host": "",
        "interval_seconds": 1,
        "password": "",
        "port": 1883,
        "retain_config": true,
        "tls": false,
        "username": ""
    },
    "open_meteo": {
        "cache_ttl_minutes": 60,
        "latitude": "32.0853",
        "longitude": "34.7818",
        "precipitation_unit": "mm",
        "temperature_unit": "celsius",
        "timeformat": "iso8601",
        "timezone": "auto",
        "units": "metric",
        "wind_speed_unit": "kmh",
        "windspeed_unit": "kmh"
    },
    "playback": {
        "animation_duration": 10,
        "animation_fps": 30,
        "delay_between_images": 30
    },
    "screen": {
        "brightness": 100,
        "off_hour": 0,
        "on_hour": 8,
        "orientation": 270,
        "schedule_enabled": false,
        "schedules": [
            {
                "days": [
                    0,
                    1,
                    2,
                    3,
                    4,
                    5,
                    6
                ],
                "enabled": false,
                "off_hour": 0,
                "on_hour": 10
            }
        ]
    },
    "stats": {
        "font_color": "yellow",
        "font_size": 20,
        "show": false
    },
    "system": {
        "image_dir": "Images",
        "image_quality_encoding": 100,
        "log_file_path": "./FrameServer/PhotoFrame.log",
        "service_name": "PhotoFrame_Desktop_App"
    },
    "ui": {
        "date_font_size": 60,
        "date_format": "ddd/MM/yyyy",
        "font_name": "arial.ttf",
        "margins": {
            "bottom": 30,
            "left": 80,
            "right": 50
        },
        "spacing_between": 50,
        "text_shadow": {
            "alpha": 230,
            "blur": 16,
            "offset_x": 2,
            "offset_y": 2
        },
        "time_font_size": 80,
        "contrast_text": true,
        "show_weather": false,
        "is_24h": false
    }
